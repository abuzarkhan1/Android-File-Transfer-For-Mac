{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "outDir": "out"
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/renderer/**/*",
    "electron.vite.config.ts"
  ]
}
